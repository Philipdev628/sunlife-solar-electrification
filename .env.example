# Copy this file to .env.local for local development.
# None of these are required for the site to build or run today —
# they're placeholders for integrations the spec flags as "future ready".

# Site URL (used for canonical URLs, sitemap, and JSON-LD). Set this to the
# real production domain once it's live.
NEXT_PUBLIC_SITE_URL=https://www.sunlifesolarelectrification.com

# Google Maps embed API key (Section 11.4 — Contact page map embed).
# If left blank, a static map link is used instead of an interactive embed.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Contact form submission endpoint. Defaults to Netlify Forms (no key
# needed). Set this only if you migrate to a third-party form service.
CONTACT_FORM_ENDPOINT=

# Analytics (optional, future-ready — not wired up yet).
NEXT_PUBLIC_GA_MEASUREMENT_ID=
